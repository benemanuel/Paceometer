<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp">

        <!-- GPS Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Acquiring GPS..."
            android:textColor="#fbbf24"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/status_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"/>

        <!-- Paceometer Gauge -->
        <com.paceometer.app.PaceometerView
            android:id="@+id/paceometerView"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginVertical="8dp"/>

        <!-- Info Panel -->
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/panel_background"
            android:padding="20dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Pace"
                android:textColor="#fb923c"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/paceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— min per 10 miles"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334155"
                android:layout_marginVertical="16dp"/>

            <TextView
                android:id="@+id/savingsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start moving to see data"
                android:textColor="#22c55e"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/insightText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS speed reads 0 when stationary"
                android:textColor="#64748b"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Research Credit -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paceometer · Peer &amp; Gamliel (2013)"
            android:textColor="#475569"
            android:textSize="11sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
